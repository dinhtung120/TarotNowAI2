# =============================================================================
# TarotNow – .gitignore
# Mục đích: Loại trừ các file không cần thiết khỏi Git repository
# Bao gồm: .NET, Node.js, macOS, IDE, secrets
# =============================================================================

# ---------- .NET ----------
## Build outputs – Thư mục chứa kết quả biên dịch
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
**/[Bb]in/
**/[Oo]bj/
**/*.dll
**/*.exe
**/*.pdb
**/*.user
**/*.suo
**/*.userosscache
**/*.sln.docstates
**/*.cache
**/*.log
[Ll]og/
[Ll]ogs/
## .NET Core
project.lock.json
project.fragment.lock.json
artifacts/
## NuGet packages
*.nupkg
*.snupkg
## User-specific project files
*.user
*.suo
*.userosscache
*.sln.docstates
## MSBuild
*.binlog
~$*
*~
## Test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
nunit-*.xml
CodeCoverage/
ScaffoldingReadMe.txt

# ---------- Node.js ----------
## Dependencies – Thư viện sẽ được cài qua npm install
node_modules/
## Build output của Next.js
.next/
out/
## Package lock debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---------- Environment & Secrets ----------
## File .env chứa secrets – KHÔNG BAO GIỜ commit lên repo
## Secrets: `.env` ở root — template committed: `.env.example`
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
## User secrets (.NET)
secrets.json

# ---------- IDE ----------
## Visual Studio
.vs/
*.rsuser
## JetBrains (Rider)
.idea/
*.sln.iml
## VS Code – Giữ lại settings chung
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ---------- macOS ----------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ---------- Testing ----------
## Coverage reports
coverage/
*.lcov
## Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# ---------- Misc ----------
*.swp
*.swo
Thumbs.db

# ---------- Runtime Artifacts ----------
nohup.out
backend_log*.txt
build_errors*.txt

