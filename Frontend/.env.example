# =============================================================================
# TarotNow Frontend – Environment Variables Template
# =============================================================================
# Cách dùng:
#   cp Frontend/.env.example Frontend/.env.local
# =============================================================================

# ---------- Required ----------
NEXT_PUBLIC_API_URL=http://localhost:5037/api/v1
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ---------- Optional (WebRTC/TURN) ----------
NEXT_PUBLIC_TURN_URLS=turn:turn.example.com:3478,turns:turn.example.com:5349
NEXT_PUBLIC_TURN_USERNAME=your-turn-username
NEXT_PUBLIC_TURN_CREDENTIAL=your-turn-password

# ---------- Optional (Call tuning) ----------
NEXT_PUBLIC_CALL_REMOTE_GAIN=2.2
NEXT_PUBLIC_CALL_RING_TIMEOUT_SECONDS=60
NEXT_PUBLIC_CALL_AUDIO_MAX_BITRATE=64000

# ---------- Optional (Server/Auth/Test) ----------
NEXTAUTH_URL=http://localhost:3000
QA_BASE_URL=http://127.0.0.1:3100
NODE_TLS_REJECT_UNAUTHORIZED=0
