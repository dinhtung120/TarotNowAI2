# =============================================================================
# TarotNow Frontend — template tham chiếu (NEXT_PUBLIC_*)
# =============================================================================
# Cấu hình thật: `.env` ở root repo. npm scripts nạp `../.env` (dotenv-cli).
# =============================================================================

# ---------- Required ----------
NEXT_PUBLIC_API_URL=http://localhost:5037/api/v1
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_CANONICAL_HOST=localhost
ENFORCE_CANONICAL_HOST=false
NEXT_ALLOWED_DEV_HOSTS=localhost,127.0.0.1

# ---------- Optional (Server/Auth/Test) ----------
NEXTAUTH_URL=http://localhost:3000
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
AUTH_VERIFIER_POLICY=fail-open
QA_BASE_URL=http://127.0.0.1:3100
# NODE_TLS_REJECT_UNAUTHORIZED chỉ dùng debug local với chứng chỉ tự ký, KHÔNG dùng production.
