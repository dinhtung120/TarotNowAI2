{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e ../.env -- next dev --hostname 0.0.0.0 --port 3000",
    "dev:pw": "next dev --hostname 127.0.0.1 --port 3100",
    "build": "dotenv -e ../.env -- next build",
    "build:analyze": "dotenv -e ../.env -- env ANALYZE=true next build --webpack",
    "start": "dotenv -e ../.env -- next start --hostname 0.0.0.0 --port 3000",
    "start:pw": "next start --hostname 127.0.0.1 --port 3100",
    "lint": "eslint && npm run lint:component-size && npm run lint:architecture && npm run lint:auth-policy && npm run lint:image-policy && npm run lint:hook-size",
    "lint:architecture": "node scripts/check-clean-architecture.mjs",
    "lint:auth-policy": "node scripts/check-auth-fail-closed.mjs",
    "lint:image-policy": "node scripts/check-next-image-policy.mjs",
    "lint:hook-size": "node scripts/check-hook-action-size.mjs",
    "lint:hook-size:sync": "node scripts/check-hook-action-size.mjs --sync",
    "lint:component-size": "node scripts/check-component-size.mjs",
    "verify:event-evidence": "node scripts/verify-backend-event-evidence.mjs",
    "knip": "npx knip --include files,dependencies,duplicates",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:risk": "npm run test:coverage && node scripts/check-risk-coverage.mjs",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "perf:gate": "node scripts/check-benchmark-gates.mjs",
    "perf:gate:latest-vs-baseline": "node scripts/check-benchmark-gates.mjs --baseline benchmark-results/benchmark/baselines/tarotnow-benchmark-baseline.json --current benchmark-results/benchmark/latest/tarotnow-benchmark.json",
    "perf:audit": "node scripts/generate-performance-audit.mjs",
    "perf:audit:latest": "PERFORMANCE_AUDIT_INPUT=benchmark-results/benchmark/latest/tarotnow-benchmark.json node scripts/generate-performance-audit.mjs",
    "perf:prod:full": "ALLOW_PRODUCTION_BENCHMARK=true RUN_NAVIGATION_BENCHMARK=true BENCHMARK_BASE_ORIGIN=https://www.tarotnow.xyz npx playwright test tests/tarotnow-navigation-benchmark.spec.ts --project=chromium",
    "perf:prod:feature": "ALLOW_PRODUCTION_BENCHMARK=true RUN_NAVIGATION_BENCHMARK_FEATURE=true BENCHMARK_BASE_ORIGIN=https://www.tarotnow.xyz npx playwright test tests/tarotnow-navigation-benchmark.spec.ts --project=chromium"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@microsoft/signalr": "^10.0.0",
    "@tanstack/react-query": "^5.95.2",
    "browser-image-compression": "^2.0.2",
    "clsx": "^2.1.1",
    "jose": "^5.10.0",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.577.0",
    "next": "^16.2.4",
    "next-intl": "^4.9.1",
    "next-qrcode": "^2.5.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "use-sync-external-store": "^1.6.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.3",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/use-sync-external-store": "^1.5.0",
    "@vitest/coverage-v8": "^4.1.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.12",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.1"
  },
  "overrides": {
    "postcss": "^8.5.12",
    "tar": ">=7.5.11"
  }
}
