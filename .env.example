# =============================================================================
# TarotNow – Root Environment Variables Template (Docker Compose only)
# =============================================================================
# Mục đích: Chỉ cấp biến cho docker-compose.yml ở root.
# Backend dùng file riêng: Backend/.env
# Frontend dùng file riêng: Frontend/.env.local
# =============================================================================

# ---------- PostgreSQL ----------
POSTGRES_USER=tarot_user
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=tarotweb
POSTGRES_PORT=5432

# ---------- MongoDB ----------
MONGO_PORT=27017

# ---------- Redis ----------
REDIS_PORT=6379
