# =============================================================================
# Một file cấu hình duy nhất ở root: sao chép thành `.env` (không commit `.env`)
# =============================================================================
#   cp .env.example .env
# - Docker Compose: tự đọc `.env` khi chạy trong thư mục repo (không cần --env-file).
# - Backend (`dotnet run`): nạp `.env` ở root (EnvLoader.cs).
# - Frontend (npm): dotenv-cli nạp `../.env`
# =============================================================================

# =============================
# Cổng map host (docker-compose.yml — stack Postgres/Mongo/Redis local)
# =============================
# Bắt buộc cho file compose dev; production compose có default nếu thiếu.
POSTGRES_PORT=5432
POSTGRES_HOST=localhost
MONGO_PORT=27017
REDIS_PORT=6379

# Tùy chọn: Cung cấp trực tiếp chuỗi kết nối (ghi đè các biến POSTGRES_* bên dưới)
# POSTGRES_CONNECTION_STRING=Host=localhost;Port=5432;Database=tarotweb;Username=tarot_user;Password=tarot_dev_pass

# =============================
# Public ingress
# =============================
PUBLIC_HTTP_PORT=80
# URL gốc canonical của site. Production phải dùng host www để tránh tách session/realtime giữa www và non-www.
PUBLIC_BASE_URL=https://www.tarotnow.example.com
# Host canonical riêng cho middleware/proxy fallback.
CANONICAL_HOST=www.tarotnow.example.com
# Host non-canonical cần redirect 301 sang CANONICAL_HOST.
NON_CANONICAL_HOST=tarotnow.example.com
# Cùng host với PUBLIC_BASE_URL để browser gọi SignalR/API same-origin.
NEXT_PUBLIC_API_URL=https://www.tarotnow.example.com/api/v1
# Host canonical dùng cho middleware fallback (Nginx vẫn là lớp redirect chính).
NEXT_PUBLIC_CANONICAL_HOST=www.tarotnow.example.com
# Bật kiểm tra fail-fast: NEXT_PUBLIC_BASE_URL phải trùng NEXT_PUBLIC_CANONICAL_HOST khi build production.
ENFORCE_CANONICAL_HOST=true
# Domain cookie auth thống nhất giữa backend API và frontend BFF.
AUTH_COOKIE_DOMAIN=www.tarotnow.example.com
NEXT_ALLOWED_DEV_HOSTS=
PRIVATE_NETWORK_SUBNET=172.30.0.0/24
# Một host Compose: tên service backend. Tách máy FE/BE: IP private của máy API.
BE_PRIVATE_IP=backend

# =============================
# PostgreSQL
# =============================
POSTGRES_USER=tarot_user
POSTGRES_PASSWORD=replace_with_strong_postgres_password
POSTGRES_DB=tarotweb

# =============================
# MongoDB / Redis
# =============================
MONGO_DB=tarotweb
REDIS_INSTANCE_NAME=TarotNow:

# =============================
# JWT
# =============================
JWT_SECRETKEY=replace_with_min_32_chars_secret
JWT_ISSUER=TarotNowAI
JWT_AUDIENCE=TarotNowAIUsers
JWT_EXPIRYMINUTES=60
JWT_REFRESHEXPIRYDAYS=7

# =============================
# Security / payment
# =============================
PAYMENT_WEBHOOK_SECRET=replace_with_strong_webhook_secret
MFA_ENCRYPTION_KEY=replace_with_strong_mfa_encryption_key

# =============================
# SMTP
# =============================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=replace_with_smtp_username
SMTP_PASSWORD=replace_with_smtp_password
SMTP_SENDER_EMAIL=noreply@example.com
SMTP_SENDER_NAME=TarotNow Security

# =============================
# AI provider
# =============================
AI_API_KEY=replace_with_ai_provider_api_key
AI_BASE_URL=https://api.openai.com/v1/
AI_MODEL=gpt-4.1-mini
AI_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=2

# =============================
# Object storage (Cloudflare R2) — upload avatar/community/chat media
# =============================
# Hard cutover: media upload mới chỉ hỗ trợ R2 direct upload.
OBJECTSTORAGE_PROVIDER=R2
# Tùy chọn
# OBJECTSTORAGE_MAX_UPLOAD_BYTES=10485760

# Bắt buộc điền đủ 5 giá trị sau (Cloudflare Dashboard → R2 → bucket)
R2_ACCOUNT_ID=replace_with_cloudflare_account_id
R2_ACCESS_KEY_ID=replace_with_r2_api_token_access_key_id
R2_SECRET_ACCESS_KEY=replace_with_r2_api_token_secret
R2_BUCKET_NAME=replace_with_bucket_name
# URL public trình duyệt tải ảnh: Custom Domain (vd https://media.example.com) hoặc Public Bucket URL (vd https://pub-xxxxx.r2.dev) — KHÔNG có slash cuối
R2_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev

# =============================
# CDN ảnh catalog lá bài (Mongo ImageUrl tương đối → API ghép thành URL tuyệt đối)
# =============================
# Trùng domain với R2 nếu bạn host cả card assets trên cùng bucket/domain. Để trống = API trả path tương đối như cũ.
MEDIACDN_PUBLIC_BASE_URL=

# Frontend next/image: hostname cho phép tải ảnh (build-time). Nên trùng host của R2_PUBLIC_BASE_URL / MEDIACDN (vd https://pub-xxxxx.r2.dev)
NEXT_PUBLIC_MEDIA_CDN_URL=
# Nếu ảnh user (R2) và ảnh bài (CDN) khác hostname, thêm URL thứ 2 (vd https://media.example.com)
NEXT_PUBLIC_R2_PUBLIC_URL=
# (Khuyến nghị bảo mật) Origin endpoint S3-compatible để browser PUT presigned URL.
# Ví dụ: https://<account-id>.r2.cloudflarestorage.com
# Nếu để trống, frontend CSP sẽ fallback cho phép https://*.r2.cloudflarestorage.com
NEXT_PUBLIC_R2_UPLOAD_ORIGIN=

# =============================
# Dev / E2E (tùy chọn)
# =============================
# QA_BASE_URL=http://127.0.0.1:3100

# =============================
# Trusted proxy network (AWS VPC CIDR)
# =============================
# Với deploy Compose trên EC2, nên trust subnet mạng private của Docker
FORWARDED_NETWORK_0=172.30.0.0/24
