# =============================================================================
# TarotNow – Environment Variables Template
# =============================================================================
# Mục đích: Template cho file .env – chứa TẤT CẢ biến môi trường cần thiết.
# Cách dùng: Copy file này thành .env và điền giá trị thật.
#   cp .env.example .env
#
# QUAN TRỌNG:
#   - KHÔNG BAO GIỜ commit file .env lên Git (đã có trong .gitignore)
#   - File này chỉ chứa placeholder, không phải secret thật
#   - Production: inject secrets qua environment variables hoặc secret store
# =============================================================================

# ---------- PostgreSQL ----------
# Cấu hình kết nối tới PostgreSQL database (ACID, finance, escrow)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tarotweb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here

# ---------- MongoDB ----------
# Cấu hình kết nối tới MongoDB (content, chat, logs)
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=tarotweb
MONGO_USER=
MONGO_PASSWORD=

# ---------- Redis ----------
# Cấu hình kết nối tới Redis (caching, rate limiting, pub/sub)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------- JWT Authentication ----------
# Cấu hình JWT tokens cho xác thực người dùng
# Secret key phải đủ dài (tối thiểu 32 ký tự) và ngẫu nhiên
JWT_SECRET=your_jwt_secret_key_at_least_32_characters_long
JWT_ISSUER=TarotNow
JWT_AUDIENCE=TarotNowApp
# Access token hết hạn nhanh (phút), refresh token dài hơn (ngày)
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# ---------- AI Provider ----------
# Cấu hình kết nối tới AI model cho Tarot reading interpretation
AI_PROVIDER_API_KEY=your_ai_api_key_here
AI_PROVIDER_BASE_URL=https://api.example.com/v1
AI_PROVIDER_MODEL=grok-3
AI_PROVIDER_TIMEOUT_SECONDS=30
AI_PROVIDER_MAX_RETRIES=2

# ---------- Email (SMTP) ----------
# Cấu hình gửi email (OTP xác minh, thông báo)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@tarotnow.com
SMTP_PASSWORD=your_smtp_password_here
SMTP_FROM_NAME=TarotNow

# ---------- Application ----------
# Cấu hình ứng dụng chung
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:5000
CORS_ORIGINS=http://localhost:3000

# ---------- Serilog ----------
# Mức log: Verbose, Debug, Information, Warning, Error, Fatal
LOG_LEVEL=Information
