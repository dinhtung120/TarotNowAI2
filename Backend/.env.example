# =============================================================================
# TarotNow Backend — template tham chiếu (ASP.NET __)
# =============================================================================
# Cấu hình thật: `.env` ở root repo (xem `.env.example`).
# `dotnet run` nạp `.env` qua EnvLoader và ánh xạ sang biến __.
# =============================================================================

# ---------- PostgreSQL Connection ----------
CONNECTIONSTRINGS__POSTGRESQL=Host=localhost;Port=5432;Database=tarotweb;Username=tarot_user;Password=your_postgres_password_here

# ---------- MongoDB Connection ----------
CONNECTIONSTRINGS__MONGODB=mongodb://localhost:27017/tarotweb

# ---------- Redis Connection ----------
CONNECTIONSTRINGS__REDIS=localhost:6379
REDIS__INSTANCENAME=TarotNow:

# ---------- JWT Authentication ----------
JWT__SECRETKEY=replace_with_strong_secret_key_min_32_chars
JWT__ISSUER=TarotNowAI
JWT__AUDIENCE=TarotNowAIUsers
JWT__EXPIRYMINUTES=60
JWT__REFRESHEXPIRYDAYS=7

# ---------- Payment Gateway ----------
PAYMENTGATEWAY__WEBHOOKSECRET=replace_with_strong_webhook_secret

# ---------- MFA / Two-Factor Authentication ----------
SECURITY__MFAENCRYPTIONKEY=replace_with_strong_mfa_encryption_key

# ---------- SMTP Email ----------
SMTP__HOST=smtp.gmail.com
SMTP__PORT=587
SMTP__USERNAME=your_smtp_username
SMTP__PASSWORD=your_smtp_password
SMTP__SENDEREMAIL=noreply@example.com
SMTP__SENDERNAME=TarotNow Security

# ---------- AI Provider ----------
AIPROVIDER__APIKEY=replace_with_ai_provider_api_key
AIPROVIDER__BASEURL=https://api.x.ai/v1/
AIPROVIDER__MODEL=grok-4-1-fast-reasoning
AIPROVIDER__TIMEOUTSECONDS=30
AIPROVIDER__MAXRETRIES=2

# ---------- CORS ----------
CORS__ALLOWEDORIGINS__0=http://localhost:3000
CORS__ALLOWEDORIGINS__1=http://192.168.0.102:3000

# ---------- API Runtime ----------
ASPNETCORE_URLS=http://0.0.0.0:5037
ASPNETCORE_ENVIRONMENT=Development
ALLOWEDHOSTS=*
AUTH__COOKIEDOMAIN=

# ---------- Logging ----------
SERILOG__MINIMUMLEVEL__DEFAULT=Information

# ---------- Reverse Proxy / Forwarded Headers ----------
FORWARDEDHEADERS__ENABLED=false
# Chỉ bật ở production sau reverse proxy và khai báo proxy/network tin cậy
# FORWARDEDHEADERS__KNOWNPROXIES__0=10.0.1.10
# FORWARDEDHEADERS__KNOWNNETWORKS__0=10.0.0.0/16

# ---------- Shared File Storage (NFS/EFS) ----------
# Để trống nếu dùng local disk. Scale ngang nên trỏ đến shared mount path.
FILESTORAGE__ROOTPATH=

# ---------- System Config ----------
SYSTEMCONFIG__DAILYAIQUOTA=100
SYSTEMCONFIG__INFLIGHTAICAP=10
SYSTEMCONFIG__READINGRATELIMITSECONDS=2
