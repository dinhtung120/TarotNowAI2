{
  "ConnectionStrings": {
    "PostgreSQL": "",
    "MongoDB": "",
    "Redis": ""
  },
  "Jwt": {
    "SecretKey": "",
    "Issuer": "TarotNowAI",
    "Audience": "TarotNowAIUsers",
    "ExpiryMinutes": 10,
    "RefreshExpiryDays": 30
  },
  "AuthSecurity": {
    "RefreshLockSeconds": 15,
    "RefreshIdempotencyWindowSeconds": 60,
    "AccessTokenBlacklistTtlSeconds": 1200,
    "SessionRevocationTtlSeconds": 1800
  },
  "PaymentGateway": {
    "WebhookSecret": ""
  },
  "Security": {
    "MfaEncryptionKey": "",
    "HttpsRedirectionEnabled": true
  },
  "Argon2": {
    "MemoryKB": 19456,
    "Iterations": 2,
    "Parallelism": 1
  },
  "Smtp": {
    "Host": "",
    "Port": 587,
    "Username": "",
    "Password": "",
    "SenderEmail": "",
    "SenderName": "TarotNow Security"
  },
  "AiProvider": {
    "ApiKey": "",
    "BaseUrl": "",
    "Model": "",
    "TimeoutSeconds": 30,
    "MaxRetries": 2
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  "FeatureManagement": {
    "AiStreamingEnabled": true,
    "ChatV2Enabled": true,
    "ChatKeywordModerationEnabled": true
  },
  "ChatModeration": {
    "Enabled": true,
    "MaxQueueSize": 2000,
    "Keywords": [
      "scam",
      "lừa đảo",
      "chuyển khoản riêng",
      "telegram",
      "zalo riêng"
    ]
  },
  "OpenTelemetry": {
    "ServiceName": "TarotNow.Api",
    "Otlp": {
      "Endpoint": ""
    }
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "SystemConfig": {
    "DailyAiQuota": 100,
    "InFlightAiCap": 10,
    "ReadingRateLimitSeconds": 2
  },
  "ForwardedHeaders": {
    "Enabled": false,
    "KnownProxies": [],
    "KnownNetworks": []
  },
  "FileStorage": {
    "RootPath": ""
  },
  "ObjectStorage": {
    "Provider": "R2",
    "MaxUploadBytes": 10485760,
    "PresignExpiryMinutes": 10,
    "CommunityOrphanTtlHours": 24,
    "CleanupBatchSize": 200,
    "CleanupIntervalMinutes": 10,
    "R2": {
      "AccountId": "",
      "AccessKeyId": "",
      "SecretAccessKey": "",
      "BucketName": "",
      "PublicBaseUrl": ""
    }
  },
  "MediaCdn": {
    "PublicBaseUrl": ""
  },
  "AllowedHosts": "*"
}
