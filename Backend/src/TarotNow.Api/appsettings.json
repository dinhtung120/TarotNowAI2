{
  /* ==========================================================================
   * TarotNow API – appsettings.json
   * Mục đích: Cấu hình chung cho ứng dụng, áp dụng ở MỌI môi trường.
   * Các giá trị nhạy cảm (secrets) được inject qua environment variables
   * hoặc User Secrets (.NET Secret Manager) – KHÔNG đặt trực tiếp ở đây.
   * ========================================================================== */
  /* Chuỗi kết nối tới các database – giá trị mặc định rỗng,
   * sẽ được override bởi appsettings.Development.json hoặc biến môi trường */
  "ConnectionStrings": {
    "PostgreSQL": "",
    "MongoDB": "",
    "Redis": ""
  },
  /* Cấu hình JWT Authentication – short-lived access token + refresh rotation
   * (ARCH-4.1.5). Secret key phải được inject qua env var ở production. */
  "Jwt": {
    "SecretKey": "",
    "Issuer": "TarotNow",
    "Audience": "TarotNowApp",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  /* Cấu hình Redis – dùng cho caching, rate limiting, pub/sub */
  "Redis": {
    "ConnectionString": "",
    "InstanceName": "TarotNow:"
  },
  /* Cấu hình AI Provider – gọi AI model để diễn giải bài Tarot
   * API key PHẢI được inject qua env var, không hardcode */
  "AiProvider": {
    "ApiKey": "",
    "BaseUrl": "",
    "Model": "grok-3",
    "TimeoutSeconds": 30,
    "MaxRetries": 2
  },
  /* Serilog structured logging – masking PII bắt buộc (OPS-5)
   * Mức log mặc định: Information. Override theo môi trường nếu cần. */
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}{NewLine}{Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  /* Cấu hình CORS – cho phép Frontend gọi API */
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  /* API versioning – base path /api/v1 */
  "ApiVersion": {
    "DefaultVersion": "1.0",
    "ReportApiVersions": true
  },
  "AllowedHosts": "*"
}