{
  "ConnectionStrings": {
    "PostgreSQL": "",
    "MongoDB": "",
    "Redis": ""
  },
  "Jwt": {
    "SecretKey": "",
    "Issuer": "TarotNowAI",
    "Audience": "TarotNowAIUsers",
    "ExpiryMinutes": 60,
    "RefreshExpiryDays": 7
  },
  "PaymentGateway": {
    "WebhookSecret": ""
  },
  "Security": {
    "MfaEncryptionKey": ""
  },
  "Argon2": {
    "MemoryKB": 19456,
    "Iterations": 2,
    "Parallelism": 1
  },
  "Redis": {
    "ConnectionString": "",
    "InstanceName": "TarotNow:"
  },
  "Smtp": {
    "Host": "",
    "Port": 587,
    "Username": "",
    "Password": "",
    "SenderEmail": "",
    "SenderName": "TarotNow Security"
  },
  "AiProvider": {
    "ApiKey": "",
    "BaseUrl": "",
    "Model": "",
    "TimeoutSeconds": 30,
    "MaxRetries": 2
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}{NewLine}{Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  "FeatureManagement": {
    "AiStreamingEnabled": true,
    "UseReadingV2": false,
    "ChatV2Enabled": true,
    "ChatKeywordModerationEnabled": true
  },
  "ChatModeration": {
    "Enabled": true,
    "MaxQueueSize": 2000,
    "Keywords": [
      "scam",
      "lừa đảo",
      "chuyển khoản riêng",
      "telegram",
      "zalo riêng"
    ]
  },
  "OpenTelemetry": {
    "ServiceName": "TarotNow.Api",
    "Otlp": {
      "Endpoint": ""
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://192.168.0.102:3000"
    ]
  },
  "ApiVersion": {
    "DefaultVersion": "1.0",
    "ReportApiVersions": true
  },
  "SystemConfig": {
    "DailyFreeGold": 5,
    "DailyAiQuota": 100,
    "InFlightAiCap": 10,
    "ReadingRateLimitSeconds": 2
  },
  "AllowedHosts": "*"
}
